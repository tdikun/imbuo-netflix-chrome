{
  "manifest_version": 3,
  "name": "Make Netflix Straight Again",
  "version": "0.1.0",
  "description": "Batch-apply LGBTQ content restrictions to Netflix profiles.",
  "permissions": ["activeTab", "tabs", "storage", "scripting", "sidePanel"],
  "host_permissions": [
    "https://www.netflix.com/*",
    "http://localhost:8001/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "panel/panel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/settings/restrictions/*"],
      "js": ["config.js", "matching.js", "content/content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
